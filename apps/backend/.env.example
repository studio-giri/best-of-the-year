DATABASE_URL=postgres://postgres:postgres@localhost:3003/best_of_the_year
PORT=3000
# Frontend origin used to compose emailed recovery links (${APP_BASE_URL}/recover/:token)
APP_BASE_URL=http://localhost:3001

# SMTP delivery for the Mailer. Local defaults target the Mailpit container
# (bun db:up); Mailpit needs no auth, so SMTP_USER / SMTP_PASS stay unset.
SMTP_HOST=localhost
SMTP_PORT=1025
MAIL_FROM=Best of the Year <noreply@bestoftheyear.local>
# SMTP_USER=
# SMTP_PASS=
