{
	"name": "backend",
	"private": true,
	"type": "module",
	"exports": {
		".": "./src/main.ts"
	},
	"scripts": {
		"dev": "bun run --hot src/main.ts",
		"typecheck": "tsgo --noEmit",
		"check": "biome check .",
		"fix": "biome check --write .",
		"db:seed": "bun run src/db/scripts/seed.ts",
		"db:truncate": "bun run src/db/scripts/truncate.ts",
		"db:migration:generate": "npx drizzle-kit generate",
		"db:migration:run": "npx drizzle-kit migrate",
		"test:unit": "bun test src",
		"test:e2e": "bun test tests"
	},
	"dependencies": {
		"@boty/shared": "workspace:*",
		"@effect/platform-bun": "4.0.0-beta.78",
		"@effect/sql-pg": "4.0.0-beta.78",
		"drizzle-orm": "1.0.0-rc.3",
		"effect": "4.0.0-beta.78",
		"pg": "8.21.0"
	},
	"devDependencies": {
		"@types/bun": "1.3.14",
		"@types/pg": "8.20.0",
		"@typescript/native-preview": "7.0.0-dev.20260603.1",
		"drizzle-kit": "1.0.0-rc.3",
		"tsx": "4.22.4"
	}
}
