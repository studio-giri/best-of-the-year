{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		// Environment-specific: server target, no DOM lib, allow JS sources
		"lib": [
			"ESNext"
		],
		"target": "ESNext",
		"module": "Preserve",
		"allowJs": true,
		// @boty/emails is consumed as raw TS source, so tsgo follows the import
		// into its react-email `.tsx` templates and needs the JSX runtime set to
		// type-check them (Bun handles JSX transparently at runtime).
		"jsx": "react-jsx"
	}
}
