{
	"extends": "../../tsconfig.base.json",
	"include": [
		"**/*.ts",
		"**/*.tsx"
	],
	"compilerOptions": {
		// Environment-specific: browser target + DOM libs, JSX, Vite client types
		"target": "ES2022",
		"module": "ESNext",
		"jsx": "react-jsx",
		"lib": [
			"ES2022",
			"DOM",
			"DOM.Iterable"
		],
		"types": [
			"vite/client"
		],
		"paths": {
			"#/*": [
				"./src/*"
			]
		},
		"noUncheckedSideEffectImports": true
	}
}
