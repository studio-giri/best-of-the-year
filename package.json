{
	"name": "best-of-the-year",
	"private": true,
	"packageManager": "bun@1.3.10",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "turbo dev",
		"check": "biome check .",
		"fix": "biome check --write .",
		"test:unit": "turbo test:unit",
		"test:e2e": "turbo test:e2e",
		"typecheck": "turbo typecheck",
		"db:up": "docker compose up",
		"db:down": "docker compose down",
		"db:logs": "docker compose logs -f db",
		"db:seed": "bun run --cwd apps/backend db:seed",
		"db:truncate": "bun run --cwd apps/backend db:truncate",
		"db:drop": "bun run --cwd apps/backend db:drop",
		"db:reset": "bun run --cwd apps/backend db:reset",
		"db:migration:generate": "bun run --cwd apps/backend db:migration:generate",
		"db:migration:run": "bun run --cwd apps/backend db:migration:run"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"turbo": "2.9.16"
	}
}
