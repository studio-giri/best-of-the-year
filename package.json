{
	"name": "best-of-the-year",
	"private": true,
	"packageManager": "bun@1.3.10",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "turbo dev",
		"check": "biome check .",
		"fix": "biome check --write .",
		"typecheck": "turbo typecheck",
		"db:up": "docker compose up",
		"db:down": "docker compose down",
		"db:logs": "docker compose logs -f db"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"turbo": "2.8.14"
	}
}
